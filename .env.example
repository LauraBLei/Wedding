# Copy these names to Vercel -> Project -> Settings -> Environment Variables.
# Never put real secrets in this file.

DROPBOX_APP_KEY=PASTE_YOUR_DROPBOX_APP_KEY_HERE
DROPBOX_APP_SECRET=PASTE_YOUR_DROPBOX_APP_SECRET_HERE
DROPBOX_REFRESH_TOKEN=PASTE_YOUR_DROPBOX_REFRESH_TOKEN_HERE

# Paths are relative to the Dropbox access selected when creating the app.
# Example for Full Dropbox access: /Wedding/Photographer 1
# Example for App Folder access: /Photographer 1
DROPBOX_FOLDER_PHOTOGRAPHER_ONE=/PASTE_FIRST_PHOTOGRAPHER_FOLDER_PATH_HERE
DROPBOX_FOLDER_PHOTOGRAPHER_TWO=/PASTE_SECOND_PHOTOGRAPHER_FOLDER_PATH_HERE
DROPBOX_FOLDER_GUESTS=/PASTE_GUEST_FOLDER_PATH_HERE
